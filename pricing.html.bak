    <meta charset="UTF-8">
    <meta name="robots" content="index, follow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pricing | Transparent Fashion Brand Building Costs </title>
    <meta name="description"
        content="Transparent pricing for fashion brand building. Explore our curated packages: Brand Launch, Brand Growth, and Brand Excellence to fit your exact budget.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,600&display=swap"
        rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link rel="stylesheet" href="style.css?v=2.0">
    <style>
        /* Pricing cards */
        .pricing-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0;
            margin-top: 80px;
            border: 1px solid rgba(0, 0, 0, .1);
        }

        .pc {
            padding: 50px 40px;
            border-right: 1px solid rgba(0, 0, 0, .1);
        }

        .pc:last-child {
            border-right: none;
        }

        .pc.featured {
            background: var(--text-primary, #111);
        }

        .pc-label {
            font-size: .68rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--text-muted);
            margin-bottom: 12px;
            display: block;
        }

        .pc.featured .pc-label {
            color: rgba(255, 255, 255, .4);
        }

        .pc h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            margin-bottom: 8px;
        }

        .pc.featured h3 {
            color: #fff;
        }

        .pc-desc {
            font-size: .85rem;
            color: var(--text-muted);
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .pc.featured .pc-desc {
            color: rgba(255, 255, 255, .5);
        }

        .pc-price {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            display: block;
            margin-bottom: 6px;
            padding-bottom: 25px;
            border-bottom: 1px solid rgba(0, 0, 0, .08);
        }

        .pc.featured .pc-price {
            color: #fff;
            border-color: rgba(255, 255, 255, .12);
        }

        .pc-cadence {
            font-size: .8rem;
            color: var(--text-muted);
            display: block;
            margin-bottom: 30px;
            margin-top: 10px;
            padding-top: 10px;
        }

        .pc.featured .pc-cadence {
            color: rgba(255, 255, 255, .4);
        }

        .pc-includes {
            list-style: none;
            margin-bottom: 35px;
        }

        .pc-includes li {
            font-size: .83rem;
            padding: 6px 0;
            border-bottom: 1px solid rgba(0, 0, 0, .05);
            color: var(--text-secondary, #444);
        }

        .pc.featured .pc-includes li {
            border-color: rgba(255, 255, 255, .07);
            color: rgba(255, 255, 255, .7);
        }

        .pc-includes li::before {
            content: "✓  ";
            color: var(--text-primary);
            font-weight: 700;
        }

        .pc.featured .pc-includes li::before {
            color: rgba(255, 255, 255, .5);
        }

        .pc-btn {
            display: block;
            padding: 14px 20px;
            text-align: center;
            font-size: .83rem;
            font-weight: 600;
            letter-spacing: .04em;
            text-decoration: none;
            transition: all .2s;
        }

        .pc-btn.outline {
            border: 1px solid var(--text-primary);
            color: var(--text-primary);
        }

        .pc-btn.outline:hover {
            background: var(--text-primary);
            color: #fff;
        }

        .pc-btn.light {
            border: 1px solid rgba(255, 255, 255, .4);
            color: #fff;
        }

        .pc-btn.light:hover {
            background: #fff;
            color: #111;
        }

        /* Comparison table */
        .compare-wrap {
            margin-top: 100px;
        }

        .compare-title {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            margin-bottom: 40px;
            text-align: center;
        }

        table.ct {
            width: 100%;
            border-collapse: collapse;
        }

        table.ct th {
            padding: 16px 20px;
            font-size: .7rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            font-weight: 700;
            border-bottom: 2px solid var(--text-primary);
            text-align: left;
        }

        table.ct th:not(:first-child) {
            text-align: center;
        }

        table.ct td {
            padding: 14px 20px;
            font-size: .85rem;
            border-bottom: 1px solid rgba(0, 0, 0, .06);
            color: var(--text-secondary, #444);
        }

        table.ct td:first-child {
            font-weight: 500;
            color: var(--text-primary);
        }

        table.ct td:not(:first-child) {
            text-align: center;
        }

        table.ct tr:hover td {
            background: #faf9f7;
        }

        .check {
            color: var(--text-primary);
            font-weight: 700;
            font-size: 1rem;
        }

        .dash {
            color: rgba(0, 0, 0, .2);
        }

        /* FAQ */
        .faq-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-top: 60px;
        }

        .faq-item {
            padding: 30px;
            border: 1px solid rgba(0, 0, 0, .08);
            background: #fff;
        }

        .faq-item h4 {
            font-size: .95rem;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .faq-item p {
            font-size: .85rem;
            color: var(--text-muted);
            line-height: 1.7;
            margin-bottom: 0;
        }

        /* Footer */
        .footer-new {
            background: #0a0a0a;
            padding: 80px 0 0
        }

        .footer-new-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1fr;
            gap: 60px;
            margin-bottom: 60px
        }

        .footer-brand p {
            color: rgba(255, 255, 255, .45);
            font-size: .88rem;
            margin-bottom: 25px;
            margin-top: 12px
        }

        .footer-brand .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            color: #fff;
            font-style: italic
        }

        .footer-col h4,
        .footer-col h3 {
            color: rgba(255, 255, 255, .4);
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .2em;
            text-transform: uppercase;
            margin-bottom: 25px
        }

        .footer-col ul {
            list-style: none
        }

        .footer-col ul li {
            margin-bottom: 12px
        }

        .footer-col ul li a {
            color: rgba(255, 255, 255, .65);
            text-decoration: none;
            font-size: .88rem
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, .07);
            padding: 28px 0;
            display: flex;
            justify-content: space-between;
            align-items: center
        }

        .footer-bottom p {
            color: rgba(255, 255, 255, .3);
            font-size: .8rem
        }

        @media(max-width:900px) {
            .pricing-cards {
                grid-template-columns: 1fr;
                border: none;
                gap: 20px;
            }

            .pc {
                border-right: none;
                border: 1px solid rgba(0, 0, 0, .1);
            }

            .pc.featured {
                border-color: transparent;
            }

            .faq-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    <link rel="icon" type="image/png" href="assets/g-favicon.png">
    <link rel="canonical" href="https://www.genixovate.com/pricing.html" />
</head>

<body>
    <nav class="navbar">
        <div class="container nav-container">
            <a href="index.html" class="logo" style="display: flex; align-items: center; text-decoration: none;"><img
                    src="assets/logo.png" alt="Genixovate"
                    style="height: 64px; width: auto; mix-blend-mode: multiply; margin-left: -15px;"></a>
            <button class="mobile-menu-btn" aria-label="Toggle menu"><i class="ph ph-list"></i></button>
            <ul class="nav-links">
                <li><a href="services.html">Services</a></li>
                <li><a href="pricing.html" class="active">Pricing</a></li>
                <li><a href="how-we-build.html">How We Build</a></li>
                <li><a href="about.html">About</a></li>
                <li><a href="contact.html" class="btn btn-primary">Start Conversation</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero -->
    <header class="hero">
        <div class="hero-video-wrapper">
            <img src="assets/hero_bg_1772274963937.png" class="hero-bg" alt="Pricing">
            <div class="hero-overlay"></div>
        </div>
        <div class="container hero-content fade-up-element" style="text-align:center;">
            <h1 class="hero-title">Transparent Pricing for Fashion Brand Growth & AI Tech</h1>
            <p class="hero-subtitle" style="max-width:560px;margin:0 auto;">Clear retainers for fashion scaling—no
                surprises, full ROI transparency.</p>
        </div>
    </header>

    <!-- Pricing Cards -->
    <section class="section relative-z" style="background:#faf9f7;">
        <div class="container fade-up-element">
            <div class="section-header" style="text-align:center;margin-bottom:60px;">
                <span class="section-kicker">Investment</span>
                <h2 class="section-title">Choose Your Path</h2>
            </div>
            <div class="pricing-cards">
                <!-- Brand Launch -->
                <li>Website &amp; sales channel foundation</li>
                </ul>
                <a href="https://calendly.com/mishitamaggo23/30min" class="pc-btn outline">Start Conversation</a>
            </div>

            <!-- Brand Growth -->
            <div class="pc featured">
                <span class="pc-label">Brand Growth</span>
                <h3>Scaling<br>Package</h3>
                <p class="pc-desc">Ongoing partnership for brands ready to build infrastructure for
                    serious growth.
                </p>
                <span class="pc-price">$4,500–$6,500/mo</span>
                <span class="pc-cadence">(retainer, based on scope)</span>
                <ul class="pc-includes">
                    <li>Full brand architecture & refresh for fashion brands</li>
                    <li>Multi-channel digital dominance (paid + organic systems)</li>
                    <li>Custom AI agents (marketing + production automation)</li>
                    <li>Weekly optimization calls & advanced analytics</li>
                    <li>Content trendjacking workflows</li>
                </ul>
                <a href="https://calendly.com/mishitamaggo23/30min" class="pc-btn light">Start Conversation</a>
            </div>

            <!-- Brand Excellence -->
            <div class="pc">
                <span class="pc-label">Brand Excellence</span>
                <h3>Established<br>Package</h3>
                <p class="pc-desc">We become your brand operations. Unlimited execution, embedded
                    strategy.</p>
                <span class="pc-price">$9,000+/mo</span>
                <span class="pc-cadence">(custom retainer)</span>
                <ul class="pc-includes">
                    <li>Tech Pack Development (First collection)</li>
                    <li>Ongoing Unlimited Size Grading System</li>
                    <li>Full Content Production Management</li>
                    <li>Website & Channel Full Management</li>
                    <li>Custom Customer Journey Automation</li>
                </ul>
                <a href="contact.html" class="pc-btn outline">Start Conversation</a>
            </div>
        </div>
        </div>
    </section>

    <!-- FAQs -->
    <section class="section relative-z" style="background:#faf9f7;">
        <div class="container fade-up-element">
            <div style="text-align:center;margin-bottom:0;">
                <span class="section-kicker">Questions</span>
                <h2 class="section-title">Common Questions</h2>
            </div>
            <div class="faq-grid">
                <div class="faq-item">
                    <h3>Is there a setup fee?</h3>
                    <p>No separate setup fee. The investment covers everything — strategy, execution, and
                        delivery.
                        Brand Launch is one fixed price, monthly services are billed monthly with no hidden
                        charges.</p>
                </div>
                <div class="faq-item">
                    <h3>What's the minimum commitment?</h3>
                    <p>Brand Launch is a one-time project. Monthly services (Brand Growth and Brand
                        Excellence) have a
                        3-month minimum to allow enough time to build and optimise the systems properly.</p>
                </div>
                <div class="faq-item">
                    <h3>Can I start with Brand Launch and move to monthly?</h3>
                    <p>Absolutely. Many clients launch with the Brand Launch package, then continue with
                        Brand Growth
                        once they're in market and ready to scale. We offer a smooth transition between
                        models.</p>
                </div>
                <div class="faq-item">
                    <h3>What if I only need one specific system?</h3>
                    <p>We offer specific systems (tech packs, content automation, etc.) starting from $1,000/mo.
                        Contact us with your exact requirement and we'll scope the right solution.</p>
                </div>
                <div class="faq-item">
                    <h3>How do payments work?</h3>
                    <p>Brand Launch: 50% upfront, 50% on delivery. Monthly services: billed monthly at the
                        start of each
                        cycle. We accept bank transfer and all major payment methods.</p>
                </div>
                <div class="faq-item">
                    <h3>Do you work with international brands?</h3>
                    <p>Yes. We work with fashion brands across India and globally. Pricing is in INR for
                        India-based
                        brands. International clients are invoiced in USD equivalent. Contact us to discuss.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section style="background:#111;padding:100px 0;text-align:center;">
        <div class="container fade-up-element">
            <h2 style="font-family:'Playfair Display',serif;font-size:2.8rem;color:#fff;margin-bottom:15px;">
                Ready to
                Start?</h2>
            <p style="color:rgba(255,255,255,.6);margin-bottom:35px;">Book a discovery call. We'll discuss
                your brand
                and recommend the right path.</p>
            <div style="display:flex;gap:20px;justify-content:center;flex-wrap:wrap;">
                <a href="contact.html"
                    style="display:inline-block;padding:16px 36px;background:#fff;color:#111;font-weight:600;font-size:.88rem;text-decoration:none;">Book
                    Discovery Call</a>
                <a href="services.html"
                    style="display:inline-block;padding:16px 36px;border:1px solid rgba(255,255,255,.3);color:#fff;font-size:.88rem;text-decoration:none;">See
                    Service Details</a>
            </div>
        </div>
    </section>


    <script src="script.js"></script>
    <!-- FOOTER -->
    <footer class="footer-new">
        <div class="container">
            <div class="footer-new-grid"
                style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 40px; max-width: 1000px;">
                <div class="footer-brand">
                    <img src="assets/logo.png" alt="Genixovate Logo" class="logo"
                        style="height: 80px; width: auto; margin-bottom: 20px; display: block; filter: invert(1); mix-blend-mode: screen; margin-left: -20px;">
                    <p style="color: rgba(255,255,255,0.6); line-height: 1.6;">Building brand infrastructure<br>for
                        modern fashion.</p>
                </div>
                <div class="footer-col" style="margin-left: auto;">
                    <h3
                        style="color: rgba(255,255,255,0.3); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">
                        Company</h3>
                    <ul style="list-style: none; padding: 0;">
                        <li><a href="about.html">About Us</a></li>
                        <li><a href="faq.html">FAQs</a></li>
                        <li><a href="tel:+919871543232">9871543232</a></li>
                    </ul>
                </div>
                <div class="footer-col" style="margin-left: auto;">
                    <h3
                        style="color: rgba(255,255,255,0.3); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px;">
                        Explore</h3>
                    <ul style="list-style: none; padding: 0;">
                        <li><a href="services.html">Services</a></li>
                        <li><a href="pricing.html">Pricing</a></li>
                        <li><a href="agents.html">Agents</a></li>
                        <li><a href="blogs.html">Blogs</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom" style="margin-top: 60px;">
                <p>&copy; 2026 Genixovate. Built for fashion founders who value systems as much as creativity.</p>
            </div>
        </div>
    </footer>
</body>

